#!/usr/bin/env python3
"""gen-pricing — build a claude-recall pricing file from a LiteLLM gateway.

Queries any LiteLLM proxy's standard ``/model/info`` endpoint and writes a JSON
pricing file (USD per 1M tokens) that claude-recall loads via the
``CLAUDE_RECALL_PRICING_FILE`` environment variable. Because ``/model/info`` is
part of the LiteLLM proxy API, this works against *any* LiteLLM-backed gateway,
not one specific endpoint.

You must provide credentials for the gateway (or already be authenticated to
it). Nothing is hardcoded:

    export LITELLM_BASE_URL=https://your-litellm-gateway.example.com
    export LITELLM_API_KEY=sk-...                  # a key valid for that gateway

    ./scripts/gen-pricing > ~/.claude/pricing.json

    # point claude-recall at it (add to your shell profile to persist):
    export CLAUDE_RECALL_PRICING_FILE=~/.claude/pricing.json

Optional:
    LITELLM_INSECURE=1   skip TLS verification (internal gateways with a private CA)

Requires: Python 3.6+ (no external dependencies).
"""

import json
import os
import ssl
import sys
import urllib.error
import urllib.request

M = 1_000_000


def per_million(x):
    """Convert a per-token rate to per-1M-tokens; None passes through."""
    return round(x * M, 6) if isinstance(x, (int, float)) else None


def main():
    base = os.environ.get("LITELLM_BASE_URL")
    key = os.environ.get("LITELLM_API_KEY")
    if not base:
        sys.exit("error: LITELLM_BASE_URL is not set.\n"
                 "  export LITELLM_BASE_URL=https://your-litellm-gateway.example.com")
    if not key:
        sys.exit("error: LITELLM_API_KEY is not set. Provide a key for the gateway "
                 "(or your login token).\n"
                 "  export LITELLM_API_KEY=sk-...")

    url = base.rstrip("/") + "/model/info"
    req = urllib.request.Request(url, headers={"Authorization": "Bearer " + key})

    ctx = None
    if os.environ.get("LITELLM_INSECURE"):
        ctx = ssl.create_default_context()
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE

    try:
        with urllib.request.urlopen(req, timeout=30, context=ctx) as resp:
            payload = json.load(resp)
    except urllib.error.HTTPError as e:
        sys.exit("error: {} returned HTTP {} {}. Check LITELLM_API_KEY / your login."
                 .format(url, e.code, e.reason))
    except urllib.error.URLError as e:
        sys.exit("error: could not reach {}: {}\n"
                 "  (for an internal gateway with a private CA, try LITELLM_INSECURE=1)"
                 .format(url, e.reason))

    out = {}
    for m in payload.get("data", []):
        name = m.get("model_name")
        info = m.get("model_info") or {}
        if not name:
            continue
        out[name] = {
            "input": per_million(info.get("input_cost_per_token")),
            "output": per_million(info.get("output_cost_per_token")),
            "cache_write": per_million(info.get("cache_creation_input_token_cost")),
            "cache_read": per_million(info.get("cache_read_input_token_cost")),
            "max_input": info.get("max_input_tokens"),
            "max_output": info.get("max_output_tokens"),
        }

    if not out:
        sys.exit("error: gateway returned no models at " + url)

    json.dump(out, sys.stdout, indent=2, sort_keys=True)
    sys.stdout.write("\n")
    print("wrote {} models from {}".format(len(out), url), file=sys.stderr)


if __name__ == "__main__":
    main()
