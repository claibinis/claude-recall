def build_parser():
    # ── Shared option groups (reused by listing + stats + export) ──
    filters = argparse.ArgumentParser(add_help=False)
    fg = filters.add_argument_group("search & filters")
    fg.add_argument("-s", "--search", help="Search by keyword(s); space-separated terms are AND by default")
    fg.add_argument("--any", action="store_true", help="Match ANY search term instead of ALL (OR)")
    fg.add_argument(
        "-f", "--full-text", action="store_true",
        help="Search transcript files too (slower); shows matching snippets",
    )
    fg.add_argument("--project", help="Filter by project name (matches the directory name)")
    fg.add_argument("--branch", help="Filter by git branch (substring)")
    fg.add_argument("--date", help="Filter by date prefix (e.g. 2026-04)")
    fg.add_argument("--since", metavar="WHEN", help="Only sessions active since 7d/24h/2w or YYYY-MM-DD")
    fg.add_argument("--until", metavar="WHEN", help="Only sessions active before 7d/24h/2w or YYYY-MM-DD")
    fg.add_argument(
        "--all", "--include-deleted", dest="all", action="store_true",
        help="Include history-only sessions whose transcript was deleted (hidden by default)",
    )

    display = argparse.ArgumentParser(add_help=False)
    dg = display.add_argument_group("display")
    dg.add_argument("--tokens", action="store_true", help="Show token usage and cost (composable)")
    dg.add_argument("--context", action="store_true", help="Show peak context window (composable)")
    dg.add_argument("--size", action="store_true", help="Show transcript file sizes (composable)")

    ordering = argparse.ArgumentParser(add_help=False)
    og = ordering.add_argument_group("ordering")
    og.add_argument("-n", "--limit", type=int, default=0, help="Limit results")
    og.add_argument("--reverse", action="store_true", help="Show oldest first")
    og.add_argument(
        "--sort", choices=["date", "recent", "tokens", "cost", "size", "messages"],
        default="date", help="Sort order (default: date; 'recent' = last activity)",
    )

    # Listing-view options shared by the default path and the `search` command.
    view = argparse.ArgumentParser(add_help=False)
    vg = view.add_argument_group("listing view")
    vg.add_argument(
        "--lines", type=int, default=_env_int("CLAUDE_RECALL_LINES", 2), metavar="N",
        help="Prompt lines per session — opening + most recent (default: 2; "
             "set CLAUDE_RECALL_LINES to change the default)",
    )
    vg.add_argument("-v", "--verbose", action="store_true", help="Show more prompt lines per session")
    vg.add_argument("--detail", action="store_true", help="Expanded per-session breakdown instead of inline")

    # ── Top-level parser (no command → listing) ──
    parser = argparse.ArgumentParser(
        prog="claude-recall",
        description="Search and manage your Claude Code sessions",
        add_help=False,  # custom -h (concise) + --help-all (full) below
        parents=[filters, display, ordering, view],
        epilog="Examples:\n"
        "  claude-recall setup                    One-time install (PATH + hooks + MCP)\n"
        "  claude-recall                          List recent sessions\n"
        "  claude-recall deploy retry             Search (bare words = search)\n"
        "  claude-recall --since 7d --tokens      Last week, with cost\n"
        "  claude-recall show cf21fedb            Read a conversation\n"
        "  claude-recall resume cf21fedb --exec   Jump back into a session\n"
        "  claude-recall name cf21 'gpu plan'     Label a session ( --clear to remove )\n"
        "  claude-recall clean --older-than 60    Delete old transcripts\n",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("-h", "--help", action="store_true", help="Show concise help")
    parser.add_argument("--help-all", action="store_true", help="Show the full option list")
    parser.add_argument("--version", action="version", version=f"%(prog)s {__version__}")

    sub = parser.add_subparsers(dest="command", metavar="COMMAND")

    p_setup = sub.add_parser("setup", help="One-command install: PATH + hooks + MCP (+ optional pricing)")
    p_setup.add_argument("--uninstall", action="store_true", help="Remove the integrations instead")
    p_setup.add_argument("-y", "--yes", action="store_true", help="Accept defaults without prompting")

    p_search = sub.add_parser("search", parents=[filters, display, ordering, view],
                              help="Search sessions by keyword(s) — same as bare `claude-recall TERMS`")
    p_search.add_argument("query", nargs="+", metavar="TERMS", help="Keywords (AND by default; --any for OR)")

    p_show = sub.add_parser("show", help="Print a session's conversation by ID prefix")
    p_show.add_argument("id", metavar="ID", help="Session ID prefix")
    p_show.add_argument("--last", type=int, default=0, metavar="N", help="Only the final N turns")
    p_show.add_argument("--grep", metavar="TERMS", help="Only show turns matching these terms")
    p_show.add_argument("--no-summary", action="store_true", help="Skip compaction-summary turns")
    p_show.add_argument("--text-only", action="store_true", help="Only turns with prose (drop tool-only turns)")

    p_resume = sub.add_parser("resume", help="Print/run the command to resume a session")
    p_resume.add_argument("id", metavar="ID", help="Session ID prefix")
    p_resume.add_argument("--exec", action="store_true", help="Run the command instead of printing it")

    sub.add_parser("stats", parents=[filters], help="Summary statistics (honors filters)")

    p_export = sub.add_parser("export", parents=[filters, display, ordering], help="Export sessions (honors filters/sort)")
    p_export.add_argument("format", choices=["csv", "json"], help="Export format")

    p_name = sub.add_parser("name", help="Label a session ( --clear to remove the label )")
    p_name.add_argument("id", metavar="ID", help="Session ID prefix")
    p_name.add_argument("name", metavar="NAME", nargs="?", help="Label to assign (omit with --clear to remove)")
    p_name.add_argument("--clear", action="store_true", help="Remove the session's label")

    p_remove = sub.add_parser("remove", help="Remove a specific session transcript by ID prefix")
    p_remove.add_argument("id", metavar="ID", help="Session ID prefix")
    p_remove.add_argument("--dry-run", action="store_true", help="Preview without deleting")
    p_remove.add_argument("-y", "--yes", action="store_true", help="Skip the confirmation prompt")

    p_clean = sub.add_parser("clean", help="Delete old transcripts ( --empty for throwaway ≤1-prompt ones )")
    p_clean.add_argument("--older-than", type=int, default=90, metavar="DAYS", help="Age threshold in days (default: 90)")
    p_clean.add_argument("--empty", action="store_true", help="Target throwaway (≤1-prompt) sessions instead of old ones")
    p_clean.add_argument("--dry-run", action="store_true", help="Preview without deleting")
    p_clean.add_argument("-y", "--yes", action="store_true", help="Skip the confirmation prompt")

    p_forget = sub.add_parser(
        "forget",
        help="Purge history-only sessions (transcript already gone) from history.jsonl",
    )
    p_forget.add_argument("--dry-run", action="store_true", help="Preview without forgetting")
    p_forget.add_argument("-y", "--yes", action="store_true", help="Skip the confirmation prompt")

    p_inst = sub.add_parser(
        "install-hooks",
        help="Install Claude Code SessionStart/SessionEnd hooks (config alternative to the cc wrapper)",
    )
    p_inst.add_argument("--uninstall", action="store_true", help="Remove the hooks instead of installing")
    p_inst.add_argument("--dry-run", action="store_true", help="Show the settings.json change without writing")

    p_hook = sub.add_parser("hook", help="(internal) handle a Claude Code hook event from stdin")
    p_hook.add_argument("event", choices=["session-start", "session-end"])

    sub.add_parser(
        "mcp",
        help="Run as an MCP server (stdio) so Claude Code can recall past sessions mid-conversation",
    )

    return parser


# Subcommand names — used to tell a command apart from bare-word search terms.
_COMMANDS = frozenset({
    "setup", "search", "show", "resume", "stats", "export", "name", "remove",
    "clean", "forget", "install-hooks", "hook", "mcp",
})


# Commands merged away in 3.0 — point users at the new form instead of silently
# treating the old name as a search term.
_RETIRED = {"unname": "name <ID> --clear", "prune-empty": "clean --empty"}


def main():
    argv = sys.argv[1:]
    if argv and argv[0] in _RETIRED:
        sys.exit("`{0}` was merged in 3.0 — use:  claude-recall {1}".format(argv[0], _RETIRED[argv[0]]))

    # Bare words are a search: `claude-recall deploy retry` ⇒ `search deploy retry`.
    # Only triggers when the first arg is a plain word that isn't a known command.
    if argv and not argv[0].startswith("-") and argv[0] not in _COMMANDS:
        argv = ["search"] + argv

    parser = build_parser()
    args = parser.parse_args(argv)

    if args.help_all:
        parser.print_help()
        return
    if args.help:
        print_short_help()
        return

    # These run before (and without) the index: setup/installer only edit config,
    # hooks must be fast, and the MCP server owns its own index lifecycle.
    if args.command == "setup":
        cmd_setup(uninstall=args.uninstall, assume_yes=args.yes)
        return
    if args.command == "hook":
        if args.event == "session-start":
            cmd_hook_session_start()
        else:
            cmd_hook_session_end()
        return
    if args.command == "install-hooks":
        cmd_install_hooks(uninstall=args.uninstall, dry_run=args.dry_run)
        return
    if args.command == "mcp":
        cmd_mcp_serve()
        return

    sessions, transcripts = build_index()

    if not sessions and not transcripts:
        print("No sessions found. Is Claude Code installed?", file=sys.stderr)
        print(f"Looked in: {CLAUDE_DIR}", file=sys.stderr)
        sys.exit(1)

    # ── Action commands (subcommands, exclusive) ──
    cmd = args.command

    # `search` is sugar for the default listing path with a query set.
    if cmd == "search":
        args.search = " ".join(args.query)
        cmd = None

    if cmd == "name":
        if args.clear or not args.name:
            cmd_unname(args.id, sessions, transcripts)
        else:
            cmd_set_name(args.id, args.name, sessions, transcripts)
        return

    if cmd == "show":
        cmd_show(args.id, sessions, transcripts, grep=args.grep,
                 last=args.last, skip_summary=args.no_summary, text_only=args.text_only)
        return

    if cmd == "resume":
        cmd_resume(args.id, sessions, transcripts, run=args.exec)
        return

    if cmd == "remove":
        cmd_remove(args.id, sessions, transcripts, args.dry_run, args.yes)
        return

    if cmd == "clean":
        if args.empty:
            cmd_prune_empty(sessions, transcripts, args.dry_run, args.yes)
        else:
            cmd_clean(sessions, transcripts, args.older_than, args.dry_run, args.yes)
        return

    if cmd == "forget":
        cmd_forget(sessions, transcripts, args.dry_run, args.yes)
        return

    # ── Build result set (search + filters; stats & export respect these) ──

    results, snippets = filter_sessions(sessions, transcripts, args)

    if cmd == "stats":
        cmd_stats(results, transcripts, scope=filters_scope(args))
        return

    # Sorting
    if args.sort == "date":
        results.sort(key=lambda x: x["first_ts"], reverse=not args.reverse)
    elif args.sort == "recent":
        results.sort(key=lambda x: x.get("last_ts", 0), reverse=not args.reverse)
    elif args.sort == "messages":
        results.sort(key=lambda x: x["msg_count"], reverse=not args.reverse)
    elif args.sort in ("tokens", "cost", "size"):
        scored = []
        for s in results:
            sid = s["id"]
            if args.sort == "size":
                score = get_session_dir_size(transcripts, sid)
            elif sid in transcripts:
                if args.sort == "tokens":
                    score = s["output_tokens"] + s["input_tokens"]
                else:
                    score = estimate_cost(s, s.get("model"))
            else:
                score = 0
            scored.append((s, score))
        scored.sort(key=lambda x: x[1], reverse=not args.reverse)
        results = [s for s, _ in scored]

    # Limit
    if args.limit:
        results = results[: args.limit]

    # ── Export ──

    if cmd == "export" and args.format == "csv":
        output = io.StringIO()
        writer = csv.writer(output)
        headers = ["session_id", "name", "start", "end", "project", "branch", "messages", "has_transcript", "first_message"]
        if args.tokens:
            headers += ["input_tokens", "output_tokens", "cache_write", "cache_read", "est_cost"]
        if args.size:
            headers.append("size_bytes")
        if args.context:
            headers.append("peak_context")
        writer.writerow(headers)

        for s in results:
            first_msg = next((m for m in s["messages"] if m and len(m) > 5), "")
            row = [
                s["id"], s.get("name", ""), format_timestamp(s["first_ts"]), format_timestamp(s["last_ts"]),
                s["project"], s.get("git_branch", ""), s["msg_count"], s["id"] in transcripts, first_msg[:200],
            ]
            if args.tokens:
                if s["id"] in transcripts:
                    cost = estimate_cost(s, s.get("model"))
                    row += [s["input_tokens"], s["output_tokens"],
                            s["cache_creation_input_tokens"],
                            s["cache_read_input_tokens"], f"{cost:.2f}"]
                else:
                    row += ["", "", "", "", ""]
            if args.size:
                row.append(get_session_dir_size(transcripts, s["id"]))
            if args.context:
                if s["id"] in transcripts:
                    row.append(s["peak_context"])
                else:
                    row.append("")
            writer.writerow(row)
        print(output.getvalue())
        return

    if cmd == "export" and args.format == "json":
        export_data = []
        for s in results:
            entry = {
                "session_id": s["id"],
                "name": s.get("name", ""),
                "start": format_timestamp(s["first_ts"]),
                "end": format_timestamp(s["last_ts"]),
                "project": s["project"],
                "msg_count": s["msg_count"],
                "has_transcript": s["id"] in transcripts,
                "git_branch": s.get("git_branch", ""),
                "resume": resume_command(s),
                "messages": s["messages"][:10],
            }
            if args.tokens and s["id"] in transcripts:
                entry["tokens"] = {
                    "input_tokens": s["input_tokens"],
                    "output_tokens": s["output_tokens"],
                    "cache_creation_input_tokens": s["cache_creation_input_tokens"],
                    "cache_read_input_tokens": s["cache_read_input_tokens"],
                    "turns": s["turns"],
                    "peak_context": s["peak_context"],
                    "model": s.get("model"),
                }
                entry["est_cost_usd"] = round(estimate_cost(s, s.get("model")), 2)
            if args.size:
                entry["size_bytes"] = get_session_dir_size(transcripts, s["id"])
            if args.context and s["id"] in transcripts:
                entry["peak_context"] = s["peak_context"]
            export_data.append(entry)
        print(json.dumps(export_data, indent=2))
        return

    # ── Display ──

    # Detail mode: expanded per-session view
    if args.detail:
        print(f"\nSession Details ({len(results)} sessions):")
        for s in results:
            print_token_detail(s, transcripts)
        return

    # Default: listing with composable enrichments. Each row shows up to
    # `--lines` substantive prompts (opening + most recent); -v bumps that.
    lines = max(1, args.lines)
    if args.verbose:
        lines = max(lines, 6)
    print(
        f"\nClaude Code Sessions ({len(results)} of {len(sessions)})  "
        f"[+ = transcript on disk, - = history only]\n"
    )
    for s in results:
        print_session(
            s, transcripts,
            show_tokens=args.tokens,
            show_size=args.size,
            show_context=args.context,
            lines=lines,
            snippet=snippets.get(s["id"], ""),
            show_last=(args.sort == "recent"),
        )

    print(
        f"\n  {len(results)} sessions  |  "
        f"{len(transcripts)} transcripts on disk  |  "
        f"{len(sessions)} total in history"
    )


if __name__ == "__main__":
    main()
