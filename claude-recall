def _resolve_or_exit(sid_prefix, sessions, transcripts):
    """Resolve a prefix to one session id, or print a message and exit."""
    resolved = resolve_session_id(sid_prefix, sessions, transcripts)
    if resolved is None:
        print(f"No session found matching '{sid_prefix}'", file=sys.stderr)
        sys.exit(1)
    if isinstance(resolved, list):
        print(f"Ambiguous prefix '{sid_prefix}' — matches {len(resolved)} sessions:", file=sys.stderr)
        for sid in resolved[:10]:
            s = sessions.get(sid, {})
            print(f"  {sid[:8]}  {project_short_name(s.get('project', ''))}", file=sys.stderr)
        sys.exit(1)
    return resolved


def cmd_resume(sid_prefix, sessions, transcripts, run=False):
    """Print (or with run=True, execute) the command to resume a session."""
    sid = _resolve_or_exit(sid_prefix, sessions, transcripts)
    session = sessions.get(sid, {})
    cwd = session.get("cwd") or session.get("project") or ""
    proj = project_short_name(cwd)
    branch = session.get("git_branch") or ""
    start = format_timestamp(session.get("first_ts", 0))
    command = resume_command(session)

    if run:
        if sid not in transcripts:
            print("⚠ Transcript not on disk (history-only) — resume may not work.", file=sys.stderr)
        print(f"  $ {command}\n")
        raise SystemExit(subprocess.call(command, shell=True))

    print(f"\n  Session:  {sid}")
    print(f"  Date:     {start}")
    print(f"  Project:  {proj}" + (f"  ({branch})" if branch else ""))
    if cwd:
        print(f"  Dir:      {cwd}")
    if sid not in transcripts:
        print(f"\n  ⚠ Transcript not on disk (history-only) — resume may not work.")

    print(f"\n  Resume with:\n")
    print(f"    {command}\n")
    print(f"  (add --exec to run it directly)\n")


def cmd_show(sid_prefix, sessions, transcripts, grep=None, last=0,
             skip_summary=False, text_only=False):
    """Pretty-print a session's conversation, collapsing tool noise.

    grep:         only show turns matching these terms (highlighted).
    last:         show only the final N turns (after grep/text-only filters).
    skip_summary: drop auto-generated compaction-summary turns.
    text_only:    drop turns with no prose (pure tool-call turns).
    """
    sid = _resolve_or_exit(sid_prefix, sessions, transcripts)
    if sid not in transcripts:
        print("No transcript on disk for this session (history-only).", file=sys.stderr)
        sys.exit(1)

    session = sessions.get(sid, {})
    terms = parse_terms(grep) if grep else []

    # Collect turns first so --last can slice the tail.
    turns = []  # (label, text, tools)
    try:
        with open(transcripts[sid]) as f:
            for line in f:
                try:
                    d = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if skip_summary and d.get("isCompactSummary"):
                    continue
                msg = d.get("message")
                if not isinstance(msg, dict):
                    continue
                t = d.get("type")
                if t == "user" and not d.get("isMeta"):
                    text = extract_user_text(msg)
                    if text:
                        turns.append(["▸ you", text, []])
                elif t == "assistant":
                    text, tools = assistant_summary(msg)
                    if not (text or tools):
                        continue
                    # Coalesce consecutive assistant messages (text + its tool
                    # calls) into one turn so tool-only lines don't count as turns.
                    if turns and turns[-1][0] == "● claude":
                        prev = turns[-1]
                        prev[1] = (prev[1] + " " + text).strip() if text else prev[1]
                        prev[2] = prev[2] + tools
                    else:
                        turns.append(["● claude", text, tools])
    except (IOError, OSError) as e:
        print(f"  Error reading transcript: {e}", file=sys.stderr)
        sys.exit(1)

    if text_only:
        turns = [tr for tr in turns if tr[1].strip()]
    if terms:
        turns = [tr for tr in turns if tr[1] and any(t in tr[1].lower() for t in terms)]

    total = len(turns)
    truncated = bool(last) and total > last
    if truncated:
        turns = turns[-last:]

    cost = estimate_cost(session, session.get("model"))
    proj = project_short_name(session.get("project", ""))
    start = format_timestamp(session.get("first_ts", 0))

    print(f"\n{'═' * 70}")
    print(f"  {sid[:8]}  |  {start}  |  {proj}  |  {session.get('model') or '?'}  |  ${cost:.2f}")
    if session.get("name"):
        print(f"  ★ {session['name']}")
    note = []
    if grep:
        note.append(f"matching: {' '.join(terms)}")
    if text_only:
        note.append("text turns only")
    if truncated:
        note.append(f"last {last} of {total} turns")
    if note:
        print(f"  ({'  |  '.join(note)})")
    print(f"{'═' * 70}")

    for label, text, tools in turns:
        _show_turn(label, text, tools, terms)
    print()


def _show_turn(label, text, tools, terms):
    """Render one collected turn (text + collapsed tool markers)."""
    text = re.sub(r"\s+", " ", text).strip()
    if terms and text:
        text = highlight(text, terms)
    print(f"\n  {label}")
    for ln in textwrap.wrap(text, width=92):
        print(f"      {ln}")
    if tools and not terms:
        print(f"      {format_tools(tools)}")


def format_tools(tools):
    """Render tool markers, collapsing consecutive repeats: 'Bash ×3'."""
    runs = []
    for tn in tools:
        if runs and runs[-1][0] == tn:
            runs[-1][1] += 1
        else:
            runs.append([tn, 1])
    return "  ".join(f"⚙ {tn}" + (f" ×{c}" if c > 1 else "") for tn, c in runs)


def assistant_summary(message):
    """Return (joined text, [tool names]) for an assistant message."""
    content = message.get("content")
    texts, tools = [], []
    if isinstance(content, str):
        texts.append(content)
    elif isinstance(content, list):
        for b in content:
            if not isinstance(b, dict):
                continue
            if b.get("type") == "text":
                texts.append(b.get("text", ""))
            elif b.get("type") == "tool_use":
                tools.append(b.get("name", "tool"))
    return " ".join(t for t in texts if t).strip(), tools


def highlight(text, terms):
    """Wrap matched terms in « » markers (no ANSI, per tool convention)."""
    for t in terms:
        text = re.sub("(" + re.escape(t) + ")", r"«\1»", text, flags=re.IGNORECASE)
    return text


def cmd_set_name(sid_prefix, name, sessions, transcripts):
    """Assign a user name to a session (stored in the sidecar)."""
    sid = _resolve_or_exit(sid_prefix, sessions, transcripts)
    names = load_names()
    names[sid] = name
    save_names(names)
    print(f"Named {sid[:8]} → ★ {name}")


def cmd_unname(sid_prefix, sessions, transcripts):
    """Remove a session's user name."""
    sid = _resolve_or_exit(sid_prefix, sessions, transcripts)
    names = load_names()
    if names.pop(sid, None) is None:
        print(f"{sid[:8]} had no name.")
        return
    save_names(names)
    print(f"Removed name from {sid[:8]}.")


def confirm(prompt, assume_yes):
    """Ask for y/N confirmation, or auto-confirm when assume_yes is set."""
    if assume_yes:
        return True
    print(prompt, end="")
    try:
        return input().strip().lower() == "y"
    except (EOFError, KeyboardInterrupt):
        print("\n  Cancelled.")
        return False


def cmd_remove(sid_prefix, sessions, transcripts, dry_run, assume_yes=False):
    """Remove a specific session's transcript by ID prefix."""
    resolved = resolve_session_id(sid_prefix, sessions, transcripts)

    if resolved is None:
        print(f"No session found matching '{sid_prefix}'", file=sys.stderr)
        sys.exit(1)

    if isinstance(resolved, list):
        print(f"Ambiguous prefix '{sid_prefix}' — matches {len(resolved)} sessions:", file=sys.stderr)
        for sid in resolved[:10]:
            print(f"  {sid[:8]}  ({sid})", file=sys.stderr)
        sys.exit(1)

    sid = resolved
    session = sessions.get(sid, {})
    proj = project_short_name(session.get("project", ""))
    start = format_timestamp(session.get("first_ts", 0))
    first_msg = ""
    for msg in session.get("messages", []):
        if msg and len(msg) > 5:
            first_msg = msg[:80]
            break

    print(f"\n  Session:  {sid}")
    print(f"  Date:     {start}")
    print(f"  Project:  {proj}")
    print(f"  Messages: {session.get('msg_count', '?')}")
    print(f"  Summary:  {first_msg}")

    if sid in transcripts:
        size = get_session_dir_size(transcripts, sid)
        print(f"  Disk:     {format_size(size)}")
    else:
        print(f"  Disk:     No transcript on disk (history-only entry)")
        print(f"\n  Nothing to remove — transcript already cleaned up.")
        return

    if dry_run:
        print(f"\n  [DRY RUN] Would delete transcript and free {format_size(size)}")
        print(f"  History index entry preserved.")
        return

    if not confirm("\n  Remove this session's transcript? [y/N] ", assume_yes):
        print("  Cancelled.")
        return

    path = transcripts[sid]
    freed = 0
    try:
        freed += path.stat().st_size
        path.unlink()
        session_dir = path.parent / sid
        if session_dir.is_dir():
            for f in session_dir.rglob("*"):
                if f.is_file():
                    freed += f.stat().st_size
            shutil.rmtree(session_dir)
    except OSError as e:
        print(f"  Error: {e}", file=sys.stderr)
        sys.exit(1)

    print(f"  Removed. Freed {format_size(freed)}.")
    print(f"  History index preserved — session still appears in search.")


def cmd_clean(sessions, transcripts, older_than_days, dry_run, assume_yes=False):
    """Interactive cleanup of old session transcripts."""
    cutoff = datetime.now() - timedelta(days=older_than_days)
    cutoff_ms = cutoff.timestamp() * 1000

    candidates = []
    for sid, path in transcripts.items():
        session = sessions.get(sid, {})
        last_ts = session.get("last_ts", 0)
        if not last_ts:
            try:
                last_ts = path.stat().st_mtime * 1000
            except OSError:
                continue

        if last_ts < cutoff_ms:
            size = get_session_dir_size(transcripts, sid)
            candidates.append((sid, path, last_ts, size))

    if not candidates:
        print(f"No transcripts older than {older_than_days} days found.")
        return

    candidates.sort(key=lambda x: x[2])
    total_size = sum(c[3] for c in candidates)

    print(f"\nFound {len(candidates)} session transcript(s) older than {older_than_days} days")
    print(f"Total reclaimable space: {format_size(total_size)}\n")

    for sid, path, ts, size in candidates:
        session = sessions.get(sid, {})
        proj = project_short_name(session.get("project", ""))
        date = format_timestamp(ts)
        first_msg = ""
        for msg in session.get("messages", []):
            if msg and len(msg) > 5:
                first_msg = msg[:50]
                break
        print(f"  {date}  [{sid[:8]}]  {format_size(size):>8}  {proj:<20}  {first_msg}")

    if dry_run:
        print(f"\n  [DRY RUN] Would delete {len(candidates)} transcript(s), freeing {format_size(total_size)}")
        print("  Note: history.jsonl entries are preserved (search still works)")
        return

    if not confirm(f"\n  Delete these {len(candidates)} transcript(s)? [y/N] ", assume_yes):
        print("  Cancelled.")
        return

    deleted = 0
    freed = 0
    for sid, path, _, size in candidates:
        try:
            path.unlink()
            freed += size
            deleted += 1
            session_dir = path.parent / sid
            if session_dir.is_dir():
                shutil.rmtree(session_dir)
        except OSError as e:
            print(f"  Error deleting {sid[:8]}: {e}", file=sys.stderr)

    print(f"  Deleted {deleted} transcript(s), freed {format_size(freed)}")
    print("  History index preserved — sessions still appear in search results")


def cmd_prune_empty(sessions, transcripts, dry_run, assume_yes=False):
    """Remove transcripts for throwaway sessions (≤1 real prompt)."""
    candidates = []
    for sid, path in transcripts.items():
        session = sessions.get(sid, {})
        if session.get("msg_count", 0) <= 1:
            size = get_session_dir_size(transcripts, sid)
            candidates.append((sid, path, session, size))

    if not candidates:
        print("No empty/throwaway sessions found.")
        return

    candidates.sort(key=lambda x: x[2].get("first_ts", 0))
    total_size = sum(c[3] for c in candidates)

    print(f"\nFound {len(candidates)} throwaway session(s) (≤1 prompt)")
    print(f"Total reclaimable space: {format_size(total_size)}\n")
    for sid, path, session, size in candidates:
        date = format_timestamp(session.get("first_ts", 0))
        proj = project_short_name(session.get("project", ""))
        first_msg = next((m for m in session.get("messages", []) if m), "")[:50]
        print(f"  {date}  [{sid[:8]}]  {format_size(size):>8}  {proj:<20}  {first_msg}")

    if dry_run:
        print(f"\n  [DRY RUN] Would delete {len(candidates)} transcript(s), freeing {format_size(total_size)}")
        print("  Note: history.jsonl entries are preserved (search still works)")
        return

    if not confirm(f"\n  Delete these {len(candidates)} transcript(s)? [y/N] ", assume_yes):
        print("  Cancelled.")
        return

    deleted = freed = 0
    for sid, path, _, size in candidates:
        try:
            path.unlink()
            freed += size
            deleted += 1
            session_dir = path.parent / sid
            if session_dir.is_dir():
                shutil.rmtree(session_dir)
        except OSError as e:
            print(f"  Error deleting {sid[:8]}: {e}", file=sys.stderr)

    print(f"  Deleted {deleted} transcript(s), freed {format_size(freed)}")
    print("  History index preserved — sessions still appear in search results")


def cmd_forget(sessions, transcripts, dry_run, assume_yes=False):
    """Purge history-only 'ghost' sessions (transcript already deleted) from
    Claude Code's history.jsonl, and drop their name labels.

    This is the ONLY path that edits history.jsonl — it is opt-in and never runs
    automatically. Sessions with a transcript on disk are left untouched.
    """
    orphans = {sid: s for sid, s in sessions.items() if sid not in transcripts}

    if not orphans:
        print("No history-only sessions to forget — every session still has a transcript.")
        return

    ordered = sorted(orphans.values(), key=lambda s: s.get("first_ts", 0))
    print(f"\nFound {len(orphans)} history-only session(s) (no transcript on disk):\n")
    for s in ordered:
        date = format_timestamp(s.get("first_ts", 0))
        proj = project_short_name(s.get("project", ""))
        first_msg = " ".join(next((m for m in s.get("messages", []) if m), "").split())[:50]
        print(f"  {date}  [{s['id'][:8]}]  {proj:<20}  {first_msg}")

    print("\n  These are NOT recoverable — the transcript is already gone.")
    print("  Forgetting drops their entries from Claude Code's history.jsonl")
    print("  (and any name labels), so they stop appearing in search.")

    if dry_run:
        print(f"\n  [DRY RUN] Would forget {len(orphans)} session(s).")
        return

    if not confirm(f"\n  Forget these {len(orphans)} session(s)? [y/N] ", assume_yes):
        print("  Cancelled.")
        return

    # Rewrite history.jsonl, dropping lines for the orphan session ids.
    removed = 0
    if HISTORY_FILE.exists():
        kept = []
        try:
            with open(HISTORY_FILE) as f:
                for line in f:
                    try:
                        d = json.loads(line)
                    except json.JSONDecodeError:
                        kept.append(line)  # keep unparseable lines untouched
                        continue
                    if d.get("sessionId", "") in orphans:
                        removed += 1
                    else:
                        kept.append(line)
            tmp = HISTORY_FILE.with_suffix(".tmp")
            with open(tmp, "w") as f:
                f.writelines(kept)
            tmp.replace(HISTORY_FILE)
        except (IOError, OSError) as e:
            print(f"  Error rewriting history.jsonl: {e}", file=sys.stderr)
            sys.exit(1)

    # Drop name labels for the forgotten sessions.
    names = load_names()
    dropped = [sid for sid in list(names) if sid in orphans]
    for sid in dropped:
        names.pop(sid, None)
    if dropped:
        save_names(names)

    print(f"  Forgot {len(orphans)} session(s) "
          f"({removed} history line(s) removed, {len(dropped)} name(s) dropped).")


# ─── Claude Code hooks (config-driven alternative to the cc wrapper) ──────────
#
# `hook session-start` / `hook session-end` are invoked by Claude Code via
# settings.json (installed by `install-hooks`). They read the hook's JSON event
# on stdin and must stay fast and crash-proof — a raised exception or slow run
# would disrupt the user's session, so every path swallows errors and exits 0.


def _git_branch(cwd):
    """Current git branch for cwd, or "" (best-effort, fast, never raises)."""
    try:
        r = subprocess.run(
            ["git", "-C", cwd, "rev-parse", "--abbrev-ref", "HEAD"],
            capture_output=True, text=True, timeout=2,
        )
        if r.returncode == 0:
            return r.stdout.strip()
    except Exception:
        pass
    return ""


def cmd_hook_session_start():
    """SessionStart hook: auto-name the session `folder@branch` via sessionTitle.

    Only `startup`/`resume` sources accept a title (per Claude Code); others are
    a no-op. Output is the hookSpecificOutput JSON Claude Code reads on stdout.
    """
    try:
        data = json.load(sys.stdin)
    except Exception:
        return
    if data.get("source", "startup") not in ("startup", "resume"):
        return
    cwd = data.get("cwd") or os.getcwd()
    title = project_short_name(cwd)
    branch = _git_branch(cwd)
    if branch and branch not in ("main", "master", "HEAD"):
        title = f"{title}@{branch}"
    print(json.dumps({
        "hookSpecificOutput": {
            "hookEventName": "SessionStart",
            "sessionTitle": title,
        }
    }))


def cmd_hook_session_end():
    """SessionEnd hook: prune the just-ended transcript if it's throwaway (≤1
    prompt). Real sessions are left untouched. Mirrors `prune-empty`, scoped to
    the one session Claude Code names on stdin."""
    try:
        data = json.load(sys.stdin)
    except Exception:
        return
    tpath = data.get("transcript_path")
    if not tpath:
        return
    path = Path(tpath)
    if not path.exists():
        return
    try:
        meta = parse_transcript(path)
        if meta.get("msg_count", 0) > 1:
            return  # real conversation — keep it
        sid = path.stem
        path.unlink()
        sub = path.parent / sid
        if sub.is_dir():
            shutil.rmtree(sub)
        print(f"claude-recall: pruned throwaway session {sid[:8]}", file=sys.stderr)
    except Exception:
        pass


# settings.json hook groups we manage, keyed by event name.
_HOOK_EVENTS = ("SessionStart", "SessionEnd")
_HOOK_TAGS = {"SessionStart": "hook session-start", "SessionEnd": "hook session-end"}


def _group_is_ours(group, tag):
    """True if a settings hook-group runs our `hook <event>` command."""
    return any(tag in h.get("command", "") for h in group.get("hooks", []))


def cmd_install_hooks(uninstall=False, dry_run=False):
    """Install (or remove) the SessionStart/SessionEnd hooks in settings.json.

    Idempotent: re-running is a no-op. Backs up settings.json before writing and
    writes atomically. The hook command points at this script's absolute path so
    it works regardless of PATH.
    """
    self_path = os.path.realpath(__file__)
    commands = {ev: f"{shlex.quote(self_path)} {_HOOK_TAGS[ev]}" for ev in _HOOK_EVENTS}

    settings = {}
    if SETTINGS_FILE.exists():
        try:
            with open(SETTINGS_FILE) as f:
                settings = json.load(f)
        except (IOError, OSError, ValueError) as e:
            print(f"Could not read {SETTINGS_FILE}: {e}", file=sys.stderr)
            sys.exit(1)
    if not isinstance(settings, dict):
        print(f"{SETTINGS_FILE} is not a JSON object — refusing to edit.", file=sys.stderr)
        sys.exit(1)

    hooks = settings.get("hooks", {})
    changed = False

    for ev in _HOOK_EVENTS:
        tag = _HOOK_TAGS[ev]
        groups = hooks.get(ev, [])
        if uninstall:
            kept = [g for g in groups if not _group_is_ours(g, tag)]
            if len(kept) != len(groups):
                changed = True
            if kept:
                hooks[ev] = kept
            elif ev in hooks:
                del hooks[ev]
        else:
            if any(_group_is_ours(g, tag) for g in groups):
                continue  # already installed
            groups.append({"hooks": [{"type": "command", "command": commands[ev]}]})
            hooks[ev] = groups
            changed = True

    if not changed:
        print("Nothing to change — claude-recall hooks are already "
              + ("absent." if uninstall else "installed."))
        return

    if hooks:
        settings["hooks"] = hooks
    else:
        settings.pop("hooks", None)

    if dry_run:
        print(f"[DRY RUN] Would write to {SETTINGS_FILE}:\n")
        print(json.dumps({"hooks": settings.get("hooks", {})}, indent=2))
        return

    if SETTINGS_FILE.exists():
        backup = SETTINGS_FILE.parent / (SETTINGS_FILE.name + ".bak")
        try:
            shutil.copy2(SETTINGS_FILE, backup)
        except OSError as e:
            print(f"Could not back up settings: {e}", file=sys.stderr)
            sys.exit(1)
    else:
        backup = None

    SETTINGS_FILE.parent.mkdir(parents=True, exist_ok=True)
    tmp = SETTINGS_FILE.parent / (SETTINGS_FILE.name + ".tmp")
    try:
        with open(tmp, "w") as f:
            json.dump(settings, f, indent=2)
        tmp.replace(SETTINGS_FILE)
    except OSError as e:
        print(f"Could not write {SETTINGS_FILE}: {e}", file=sys.stderr)
        sys.exit(1)

    if uninstall:
        print(f"Removed claude-recall hooks from {SETTINGS_FILE}")
    else:
        print(f"Installed claude-recall hooks in {SETTINGS_FILE}:")
        print("  • SessionStart → auto-names the session  (folder@branch)")
        print("  • SessionEnd   → prunes throwaway (≤1-prompt) sessions on exit")
    if backup:
        print(f"  Previous settings backed up to {backup}")
    print("  Restart Claude Code (or start a new session) for it to take effect.")


def cmd_setup(uninstall=False, assume_yes=False):
    """One command to install and wire up everything: put claude-recall on PATH,
    install the Claude Code hooks (auto-naming + exit-pruning), register the MCP
    server, and optionally set up custom pricing. Idempotent and reversible."""
    script = os.path.realpath(__file__)
    bindir = Path.home() / ".local" / "bin"
    link = bindir / "claude-recall"

    def claude_on_path():
        return shutil.which("claude") is not None

    if uninstall:
        print("Removing claude-recall integrations…\n")
        if claude_on_path():
            subprocess.call(["claude", "mcp", "remove", "claude-recall"],
                            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            print("  ✓ unregistered MCP server")
        cmd_install_hooks(uninstall=True)
        try:
            if link.is_symlink() and os.path.realpath(link) == script:
                link.unlink()
                print(f"  ✓ removed {link}")
        except OSError:
            pass
        print("\nDone. (Your clone is untouched — delete it to remove completely.)")
        return

    print("Setting up claude-recall…\n")

    # 1. PATH — symlink into ~/.local/bin so `claude-recall` works anywhere.
    found = shutil.which("claude-recall")
    if found and os.path.realpath(found) == script:
        print("  ✓ already on your PATH")
    else:
        try:
            bindir.mkdir(parents=True, exist_ok=True)
            if link.exists() or link.is_symlink():
                link.unlink()
            link.symlink_to(script)
            print(f"  ✓ linked into {link}")
            if str(bindir) not in os.environ.get("PATH", "").split(os.pathsep):
                print(f"    ↳ add {bindir} to your PATH (e.g. in ~/.zshrc) to use it everywhere")
        except OSError as e:
            print(f"  ! couldn't link into {bindir}: {e}")
            print(f"    run it directly instead: {script}")

    # 2. Hooks — auto-name sessions, prune throwaway ones on exit.
    print()
    cmd_install_hooks()

    # 3. MCP server — let Claude recall past sessions mid-conversation.
    print()
    if claude_on_path():
        rc = subprocess.call(["claude", "mcp", "add", "claude-recall", "--", script, "mcp"],
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        if rc == 0:
            print("  ✓ registered MCP server — Claude can now recall your sessions")
        else:
            print("  • MCP server already registered (or declined) — left as-is")
    else:
        print("  • 'claude' CLI not found — skipped MCP registration")
        print(f"    later:  claude mcp add claude-recall -- {script} mcp")

    # 4. Pricing (optional) — only if the user wants custom/gateway rates.
    print()
    if confirm("  Set up custom token pricing now (LiteLLM gateway)? [y/N] ", assume_yes):
        gp = os.path.join(os.path.dirname(script), "scripts", "gen-pricing")
        if os.path.exists(gp) and os.environ.get("LITELLM_BASE_URL"):
            subprocess.call([sys.executable, gp])
        else:
            print("    Set LITELLM_BASE_URL / LITELLM_API_KEY, then run: scripts/gen-pricing")
            print("    (or drop a pricing.json next to claude-recall). Using built-in rates for now.")
    else:
        print("  • Using built-in pricing (run scripts/gen-pricing anytime to customize)")

    print("\nAll set. Try:")
    print("  claude-recall            list recent sessions")
    print("  claude-recall deploy     search for 'deploy'")


# ─── MCP server (stdio, newline-delimited JSON-RPC 2.0; zero dependencies) ────
#
# Exposes the existing index as MCP tools so Claude Code can recall past
# sessions *mid-conversation* (search, read verbatim, list recent, cost) by
# calling tools itself — the "memory" capability comparable tools provide,
# built on claude-recall's own search/cost engine. The protocol is spoken
# directly over stdin/stdout, so there's still nothing to `pip install`.
# Register it (one time) with:
#
#     claude mcp add claude-recall -- claude-recall mcp
#
MCP_PROTOCOL_VERSION = "2024-11-05"


def _mcp_tools():
    """Tool definitions advertised to the MCP client (Claude Code)."""
    proj_prop = {"type": "string", "description": "Limit to a project (directory-name substring)."}
    limit_prop = {"type": "integer", "description": "Max results (default 10)."}
    return [
        {
            "name": "search_sessions",
            "description": (
                "Search the user's past Claude Code sessions by keyword to recall "
                "earlier decisions, context, and conversations. Returns matching "
                "sessions with date, project, a matching snippet, and a resume "
                "command. Call this whenever the user refers to something discussed "
                "or decided in a previous session."
            ),
            "inputSchema": {
                "type": "object",
                "properties": {
                    "query": {"type": "string", "description": "Keywords; space-separated terms must all match unless 'any' is true."},
                    "full_text": {"type": "boolean", "description": "Also scan full transcript bodies, not just prompts/names (slower). Default false."},
                    "any": {"type": "boolean", "description": "Match ANY term (OR) instead of ALL (AND). Default false."},
                    "project": proj_prop,
                    "limit": limit_prop,
                },
                "required": ["query"],
            },
        },
        {
            "name": "read_session",
            "description": (
                "Return the conversation transcript of one past session by ID (or a "
                "unique ID prefix from search_sessions), so you can quote the user's "
                "exact earlier words rather than a paraphrase. Optionally restrict to "
                "the last N turns or to turns matching search terms."
            ),
            "inputSchema": {
                "type": "object",
                "properties": {
                    "id": {"type": "string", "description": "Session ID or unique prefix."},
                    "last": {"type": "integer", "description": "Only the final N turns."},
                    "grep": {"type": "string", "description": "Only turns containing these terms."},
                },
                "required": ["id"],
            },
        },
        {
            "name": "recent_sessions",
            "description": (
                "List the most recently active past sessions (optionally for one "
                "project) to recall what was being worked on lately."
            ),
            "inputSchema": {
                "type": "object",
                "properties": {"project": proj_prop, "limit": limit_prop},
            },
        },
        {
            "name": "session_cost",
            "description": (
                "Report token usage and estimated USD cost across past sessions "
                "(optionally for one project), using claude-recall's pricing "
                "(built-in rates or a configured LiteLLM/discounted pricing file)."
            ),
            "inputSchema": {
                "type": "object",
                "properties": {"project": proj_prop},
            },
        },
    ]


def _mcp_brief(session, transcripts, snippet=""):
    """One compact, LLM-readable block describing a session."""
    sid = session["id"]
    proj = project_short_name(session.get("project") or session.get("cwd"))
    head = "[{}] {} · {}".format(sid[:8], format_timestamp(session.get("last_ts")), proj)
    branch = session.get("git_branch", "")
    if branch and branch not in ("main", "master", "HEAD"):
        head += "@" + branch
    if session.get("name"):
        head += " · ★ " + session["name"]
    lines = [head]
    if snippet:
        lines.append("  ↳ " + snippet)
    else:
        for p in session_prompts(session, limit=2):
            lines.append("  • " + p[:200])
    lines.append("  resume: " + resume_command(session))
    return "\n".join(lines)


def _mcp_project_match(session, needle):
    """True if a session's project name contains `needle` (already lowercased)."""
    return needle in project_short_name(session.get("project") or session.get("cwd")).lower()


def _mcp_call_tool(name, arguments):
    """Run one MCP tool and return its text payload. ValueError → tool error."""
    args = arguments or {}
    sessions, transcripts = build_index()  # cheap (cache); keeps recall fresh
    recallable = [s for s in sessions.values() if s.get("has_transcript")]

    project = (args.get("project") or "").strip().lower()
    if project:
        recallable = [s for s in recallable if _mcp_project_match(s, project)]

    if name == "search_sessions":
        query = (args.get("query") or "").strip()
        if not query:
            raise ValueError("query is required")
        terms = parse_terms(query)
        any_mode = bool(args.get("any"))
        limit = max(1, int(args.get("limit") or 10))
        snippets = {}

        if args.get("full_text"):
            subset = {s["id"]: transcripts[s["id"]] for s in recallable if s["id"] in transcripts}
            snippets = search_transcripts(terms, subset, any_mode)
            hits = [s for s in recallable if s["id"] in snippets]
        else:
            hits = []
            for s in recallable:
                hay = " ".join(s.get("messages", []) + [
                    s.get("name", ""), s.get("first_assistant", ""),
                    project_short_name(s.get("project") or s.get("cwd")),
                ])
                if terms_match(hay, terms, any_mode):
                    hits.append(s)
                    snip = first_snippet(s.get("messages", []), terms)
                    if snip:
                        snippets[s["id"]] = snip

        hits.sort(key=lambda x: x.get("last_ts", 0), reverse=True)
        hits = hits[:limit]
        if not hits:
            return "No matching sessions found for: " + query
        blocks = [_mcp_brief(s, transcripts, snippets.get(s["id"], "")) for s in hits]
        return "{} session(s) matching '{}':\n\n{}".format(len(hits), query, "\n\n".join(blocks))

    if name == "read_session":
        prefix = (args.get("id") or "").strip()
        if not prefix:
            raise ValueError("id is required")
        match = resolve_session_id(prefix, sessions, transcripts)
        if match is None:
            return "No session matches id prefix: " + prefix
        if isinstance(match, list):
            return "Ambiguous id prefix '{}' — matches {} sessions: {}".format(
                prefix, len(match), ", ".join(m[:8] for m in match[:10]))
        # Reuse cmd_show's renderer by capturing its stdout (no new dependency).
        saved, sys.stdout = sys.stdout, io.StringIO()
        try:
            cmd_show(match, sessions, transcripts, grep=args.get("grep"),
                     last=int(args.get("last") or 0))
            text = sys.stdout.getvalue()
        finally:
            sys.stdout = saved
        return text.strip() or "(empty session)"

    if name == "recent_sessions":
        limit = max(1, int(args.get("limit") or 10))
        recallable.sort(key=lambda x: x.get("last_ts", 0), reverse=True)
        recallable = recallable[:limit]
        if not recallable:
            return "No sessions found."
        return "\n\n".join(_mcp_brief(s, transcripts) for s in recallable)

    if name == "session_cost":
        total = sum(estimate_cost(s, s.get("model")) for s in recallable)
        toks = sum(s["input_tokens"] + s["output_tokens"] for s in recallable)
        scope = " for project '{}'".format(project) if project else ""
        return ("{} session(s){}\n"
                "  total tokens (in+out): {}\n"
                "  estimated cost: ${:,.2f}").format(len(recallable), scope, format_tokens(toks), total)

    raise ValueError("unknown tool: " + str(name))


def cmd_mcp_serve():
    """Serve the MCP tools over stdio. Reads newline-delimited JSON-RPC 2.0
    requests on stdin, writes responses on stdout. Never crashes on a single bad
    request — malformed lines are ignored and tool errors are returned in-band."""
    out = sys.stdout  # captured up front; read_session swaps sys.stdout briefly

    def send(obj):
        out.write(json.dumps(obj) + "\n")
        out.flush()

    def reply(rid, payload):
        send({"jsonrpc": "2.0", "id": rid, "result": payload})

    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            req = json.loads(line)
        except ValueError:
            continue  # ignore malformed input
        rid = req.get("id")
        method = req.get("method")
        params = req.get("params") or {}

        if method == "initialize":
            reply(rid, {
                "protocolVersion": MCP_PROTOCOL_VERSION,
                "capabilities": {"tools": {}},
                "serverInfo": {"name": "claude-recall", "version": __version__},
            })
        elif method == "tools/list":
            reply(rid, {"tools": _mcp_tools()})
        elif method == "tools/call":
            try:
                text = _mcp_call_tool(params.get("name"), params.get("arguments"))
                reply(rid, {"content": [{"type": "text", "text": text}], "isError": False})
            except ValueError as e:
                reply(rid, {"content": [{"type": "text", "text": "error: " + str(e)}], "isError": True})
            except Exception as e:  # one bad call must not kill the server
                reply(rid, {"content": [{"type": "text", "text": "internal error: " + str(e)}], "isError": True})
        elif method == "ping":
            reply(rid, {})
        elif rid is not None:
            # A request (has id) we don't implement; notifications (no id) are ignored.
            send({"jsonrpc": "2.0", "id": rid, "error": {"code": -32601, "message": "method not found: " + str(method)}})


def cmd_stats(session_list, transcripts, scope=""):
    """Show summary statistics over a (possibly filtered) list of sessions.

    scope: a label like "project=my-project" appended to the header when the
    stats cover a filtered subset rather than everything.
    """
    projects = defaultdict(int)
    total_msgs = 0
    dates = []
    total_tokens = {"input": 0, "output": 0, "cache_write": 0, "cache_read": 0}
    total_cost = 0.0
    total_disk = 0
    on_disk = [s for s in session_list if s["id"] in transcripts]

    for s in session_list:
        projects[project_short_name(s["project"])] += 1
        total_msgs += s["msg_count"]
        if s["first_ts"]:
            dates.append(s["first_ts"])

    for s in on_disk:
        total_disk += get_session_dir_size(transcripts, s["id"])
        total_tokens["input"] += s["input_tokens"]
        total_tokens["output"] += s["output_tokens"]
        total_tokens["cache_write"] += s["cache_creation_input_tokens"]
        total_tokens["cache_read"] += s["cache_read_input_tokens"]
        total_cost += estimate_cost(s, s.get("model"))

    label = "Sessions (filtered):" if scope else "Sessions in history: "
    print(f"{label}   {len(session_list)}" + (f"   [{scope}]" if scope else ""))
    print(f"Transcripts on disk:    {len(on_disk)}")
    print(f"Total prompts:          {total_msgs}")
    print(f"Disk usage:             {format_size(total_disk)}")
    if dates:
        print(
            f"Date range:             {format_timestamp(min(dates))} → {format_timestamp(max(dates))}"
        )
    print(f"\nToken Usage (transcripts on disk):")
    print(f"  Input:                {format_tokens(total_tokens['input'])}")
    print(f"  Output:               {format_tokens(total_tokens['output'])}")
    print(f"  Cache write:          {format_tokens(total_tokens['cache_write'])}")
    print(f"  Cache read:           {format_tokens(total_tokens['cache_read'])}")
    print(f"  Estimated total cost: ${total_cost:.2f}")

    # Cache efficiency: how much input-side work was served from cache, and which
    # sessions paid to write cache they barely reused.
    overall = cache_reuse_ratio({
        "cache_read_input_tokens": total_tokens["cache_read"],
        "cache_creation_input_tokens": total_tokens["cache_write"],
        "input_tokens": total_tokens["input"],
    })
    low_reuse = []
    for s in on_disk:
        write = s["cache_creation_input_tokens"]
        if write >= 50_000 and cache_reuse_ratio(s) < 0.5:
            low_reuse.append((write - s["cache_read_input_tokens"], s))
    print(f"\nCache efficiency:")
    print(f"  Reuse ratio:          {overall * 100:.0f}%   (reads / all input tokens)")
    if low_reuse:
        low_reuse.sort(key=lambda x: -x[0])
        print(f"  Low-reuse sessions (paid to write cache, reused little):")
        for _, s in low_reuse[:5]:
            proj = project_short_name(s.get("project", ""))
            print(f"    [{s['id'][:8]}] {proj:<18} "
                  f"write {format_tokens(s['cache_creation_input_tokens']):>7}  "
                  f"read {format_tokens(s['cache_read_input_tokens']):>7}  "
                  f"reuse {cache_reuse_ratio(s) * 100:>3.0f}%")

    print(f"\nBy project:")
    for proj, count in sorted(projects.items(), key=lambda x: -x[1]):
        print(f"  {count:>4}  {proj}")


def filter_sessions(sessions, transcripts, args):
    """Apply search + filters from args. Returns (results_list, snippets)."""
    results = list(sessions.values())
    snippets = {}

    # By default, hide history-only "ghost" sessions (transcript deleted — not
    # recoverable). --all/--include-deleted brings them back.
    if not getattr(args, "all", False):
        results = [s for s in results if s["id"] in transcripts]

    # Search — space-separated terms, AND by default (--any for OR)
    if args.search:
        terms = parse_terms(args.search)
        text_matches = set()
        for sid, s in sessions.items():
            hay = " ".join(s["messages"] + [s.get("name", ""), s.get("project", "")])
            if terms_match(hay, terms, args.any):
                text_matches.add(sid)
                snip = first_snippet(s["messages"], terms)
                if snip:
                    snippets[sid] = snip
        if args.full_text:
            for sid, snip in search_transcripts(terms, transcripts, args.any).items():
                text_matches.add(sid)
                snippets.setdefault(sid, snip)
        results = [s for s in results if s["id"] in text_matches]

    if args.project:
        pf = args.project.lower()
        results = [s for s in results if pf in project_short_name(s.get("project", "")).lower()]

    if args.branch:
        bf = args.branch.lower()
        results = [s for s in results if bf in (s.get("git_branch", "") or "").lower()]

    if args.date:
        results = [s for s in results if format_timestamp(s["first_ts"]).startswith(args.date)]

    if args.since:
        cutoff = parse_when(args.since)
        if cutoff is None:
            print(f"Could not parse --since '{args.since}' (try 7d, 24h, 2w, or YYYY-MM-DD)", file=sys.stderr)
            sys.exit(1)
        results = [s for s in results if s.get("last_ts", 0) >= cutoff]

    if args.until:
        cutoff = parse_when(args.until)
        if cutoff is None:
            print(f"Could not parse --until '{args.until}' (try 7d, 24h, 2w, or YYYY-MM-DD)", file=sys.stderr)
            sys.exit(1)
        results = [s for s in results if s.get("last_ts", 0) <= cutoff]

    return results, snippets


def filters_scope(args):
    """Short label describing active filters, for the stats header (or "")."""
    parts = []
    if args.search:
        parts.append(("any:" if args.any else "all:") + args.search)
    if args.project:
        parts.append(f"project={args.project}")
    if args.branch:
        parts.append(f"branch={args.branch}")
    if args.date:
        parts.append(f"date={args.date}")
    if args.since:
        parts.append(f"since={args.since}")
    if args.until:
        parts.append(f"until={args.until}")
    return ", ".join(parts)


