#!/usr/bin/env python3
"""claude-recall — Search, analyze, and manage your Claude Code sessions.

A standalone tool that indexes ~/.claude session data, providing keyword search,
token usage reporting, cost estimation, and cleanup utilities.

Requires: Python 3.6+ (no external dependencies)
"""

import argparse
import csv
import io
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import textwrap
from datetime import datetime, timedelta, timezone
from pathlib import Path
from collections import defaultdict

__version__ = "3.1.0"

CLAUDE_DIR = Path(os.environ.get("CLAUDE_DIR", Path.home() / ".claude"))
HISTORY_FILE = CLAUDE_DIR / "history.jsonl"
PROJECTS_DIR = CLAUDE_DIR / "projects"
SETTINGS_FILE = CLAUDE_DIR / "settings.json"

# Metadata cache: transcripts are parsed once and reused until their mtime/size
# changes. Bump CACHE_VERSION when the cached `meta` shape changes.
CACHE_FILE = CLAUDE_DIR / ".claude-recall-cache.json"
CACHE_VERSION = 6

# Sidecar store for user-assigned session names (never touches transcripts).
NAMES_FILE = CLAUDE_DIR / ".claude-recall-names.json"

# Claude pricing per 1M tokens (USD) — adjust as rates change
PRICING = {
    "claude-opus-4": {"input": 15.00, "output": 75.00, "cache_write": 18.75, "cache_read": 1.50},
    "claude-sonnet-4": {"input": 3.00, "output": 15.00, "cache_write": 3.75, "cache_read": 0.30},
    "claude-haiku-4": {"input": 0.80, "output": 4.00, "cache_write": 1.00, "cache_read": 0.08},
    "default": {"input": 15.00, "output": 75.00, "cache_write": 18.75, "cache_read": 1.50},
}

# Per-model context window (tokens). A session's peak context is flagged when it
# nears the model's limit, rather than against a single hardcoded number.
CONTEXT_LIMITS = {
    "claude-opus-4": 200_000,
    "claude-sonnet-4": 1_000_000,
    "claude-haiku-4": 200_000,
    "default": 200_000,
}
# Warn when peak context exceeds this fraction of the model's window.
CONTEXT_WARN_RATIO = float(os.environ.get("CLAUDE_RECALL_CTX_WARN", "0.9"))


def _pricing_file():
    """Locate the pricing-overrides file. Resolution order:

    1. ``CLAUDE_RECALL_PRICING_FILE`` if set (explicit override).
    2. ``pricing.json`` next to this script (where the command lives).
    3. ``pricing.json`` in ``CLAUDE_DIR`` (~/.claude).

    Returns a Path (env case: even if missing, so a bad path warns), or None.
    """
    env = os.environ.get("CLAUDE_RECALL_PRICING_FILE")
    if env:
        return Path(env).expanduser()
    for cand in (Path(os.path.realpath(__file__)).parent / "pricing.json",
                 CLAUDE_DIR / "pricing.json"):
        if cand.exists():
            return cand
    return None


def _load_pricing_overrides():
    """Merge per-model rates from a pricing file over the built-in defaults.

    The file is JSON keyed by model name, with rates in USD per 1M tokens, e.g.

        {"your-model-name": {"input": 3.00, "output": 15.00,
                             "cache_write": 3.75, "cache_read": 0.30,
                             "max_input": 200000}}

    Generate it for any LiteLLM gateway with scripts/gen-pricing (which writes
    pricing.json next to this script by default, so it's picked up with no env
    var). Keys starting with "_" (e.g. "_meta") are ignored. With no file the
    built-in defaults are used unchanged.
    """
    path = _pricing_file()
    if not path:
        return
    try:
        data = json.loads(path.read_text())
    except (OSError, ValueError) as e:
        print("warning: could not load pricing file ({}): {}".format(path, e), file=sys.stderr)
        return
    for model, fields in data.items():
        if model.startswith("_") or not isinstance(fields, dict):
            continue
        rate = {k: fields[k] for k in ("input", "output", "cache_write", "cache_read")
                if isinstance(fields.get(k), (int, float))}
        if rate:
            PRICING[model] = rate
        if isinstance(fields.get("max_input"), (int, float)):
            CONTEXT_LIMITS[model] = int(fields["max_input"])


_load_pricing_overrides()


def _best_match(model, table):
    """Return the table value whose key is the longest substring of `model`.

    Longest-key wins so a specific entry (``claude-opus-4-8``) beats a generic
    one (``claude-opus-4``). Falls back to the ``default`` entry.
    """
    if model:
        best = None
        for key in table:
            if key != "default" and key in model and (best is None or len(key) > len(best)):
                best = key
        if best is not None:
            return table[best]
    return table["default"]


def context_limit(model):
    """Return the context window size for a model name (longest-match)."""
    return _best_match(model, CONTEXT_LIMITS)


def context_warns(peak, model):
    """True when peak context is close enough to the model's window to flag."""
    return peak > context_limit(model) * CONTEXT_WARN_RATIO


def _env_int(name, default):
    """Read an integer env var, falling back to default on unset/invalid."""
    try:
        return int(os.environ[name])
    except (KeyError, ValueError):
        return default


# ─── Data Loading ────────────────────────────────────────────────────────────


def to_ms(ts):
    """Normalize a timestamp to epoch milliseconds.

    Handles ISO-8601 strings (transcript format, e.g. '2026-06-01T13:53:14.255Z')
    and numeric epochs in either seconds or milliseconds (history.jsonl format).
    """
    if not ts:
        return 0
    if isinstance(ts, (int, float)):
        # 13-digit values are already ms; smaller values are seconds.
        return int(ts if ts > 1e11 else ts * 1000)
    s = str(ts).strip()
    try:
        dt = datetime.fromisoformat(s.replace("Z", "+00:00"))
        return int(dt.timestamp() * 1000)
    except (ValueError, AttributeError):
        pass
    try:  # Python 3.6 fallback (no datetime.fromisoformat)
        base = s.replace("Z", "").split("+")[0].split(".")[0]
        dt = datetime.strptime(base, "%Y-%m-%dT%H:%M:%S").replace(tzinfo=timezone.utc)
        return int(dt.timestamp() * 1000)
    except (ValueError, AttributeError):
        return 0


def clean_display(text):
    """Reduce a raw user message to a readable prompt for the index.

    Slash commands arrive wrapped as '<command-name>/init</command-name>...';
    surface just the command. Otherwise strip XML-ish wrapper tags (command
    output, caveats, system reminders) and collapse whitespace.
    """
    if not text:
        return ""
    text = re.sub(r"\x1b\[[0-9;]*m", "", text)  # strip ANSI color/style codes
    m = re.search(r"<command-name>([^<]*)</command-name>", text)
    if m:
        return m.group(1).strip()
    if re.search(r"<(?:local-command-std(?:out|err)|bash-(?:input|stdout|stderr))>", text):
        return ""  # captured command I/O (! commands, tool output), not a typed prompt
    stripped = re.sub(r"</?[a-z][a-z0-9-]*>", " ", text)
    return re.sub(r"\s+", " ", stripped).strip()


def extract_user_text(message):
    """Pull the typed-prompt text out of a transcript 'user' message.

    Content is either a plain string or a list of blocks; only 'text' blocks are
    real prompts (tool_result blocks are skipped naturally).
    """
    content = message.get("content")
    if isinstance(content, str):
        return clean_display(content)
    if isinstance(content, list):
        parts = [
            b.get("text", "")
            for b in content
            if isinstance(b, dict) and b.get("type") == "text"
        ]
        return clean_display(" ".join(p for p in parts if p))
    return ""


def parse_transcript(path):
    """Single-pass extraction of session metadata + token usage from a transcript.

    Returns the `meta` dict that gets cached. One read of the file yields the
    project dir (cwd), git branch, timestamps, user prompts, model, and token
    totals — so no consumer needs to re-open the transcript.
    """
    meta = {
        "messages": [],
        "msg_count": 0,
        "first_assistant": "",
        "first_ts": 0,
        "last_ts": 0,
        "cwd": "",
        "git_branch": "",
        "model": None,
        "input_tokens": 0,
        "output_tokens": 0,
        "cache_creation_input_tokens": 0,
        "cache_read_input_tokens": 0,
        "turns": 0,
        "peak_context": 0,
        "color": "",          # last /color (agent-color line); "" = default
        "custom_title": "",   # /name or /rename (Claude's own session title)
    }

    try:
        with open(path) as f:
            for line in f:
                try:
                    d = json.loads(line)
                except json.JSONDecodeError:
                    continue

                ts = to_ms(d.get("timestamp"))
                if ts:
                    if not meta["first_ts"] or ts < meta["first_ts"]:
                        meta["first_ts"] = ts
                    if ts > meta["last_ts"]:
                        meta["last_ts"] = ts

                if not meta["cwd"] and d.get("cwd"):
                    meta["cwd"] = d["cwd"]
                if not meta["git_branch"] and d.get("gitBranch"):
                    meta["git_branch"] = d["gitBranch"]

                # Session color (`/color`) and title (`/name`/`/rename`) are stored
                # as their own transcript lines; the last value wins. Capture these
                # before the message-only filter below (these lines carry no message).
                if d.get("type") == "agent-color" and d.get("agentColor"):
                    meta["color"] = d["agentColor"]
                if d.get("customTitle"):
                    meta["custom_title"] = d["customTitle"]

                msg = d.get("message")
                if not isinstance(msg, dict):
                    continue

                if d.get("type") == "user" and not d.get("isMeta"):
                    text = extract_user_text(msg)
                    if text:
                        meta["messages"].append(text[:500])
                        meta["msg_count"] += 1

                # First thing Claude said — a fallback label for sessions whose
                # user turns are all trivia (extract_user_text reads text blocks
                # from either role).
                elif d.get("type") == "assistant" and not meta["first_assistant"]:
                    atext = extract_user_text(msg)
                    if atext and not is_trivial_prompt(atext):
                        meta["first_assistant"] = atext[:300]

                model = msg.get("model")
                if not meta["model"] and model and not model.startswith("<"):
                    meta["model"] = model  # skip placeholders like "<synthetic>"

                usage = msg.get("usage")
                if isinstance(usage, dict) and usage:
                    meta["turns"] += 1
                    meta["input_tokens"] += usage.get("input_tokens", 0)
                    meta["output_tokens"] += usage.get("output_tokens", 0)
                    meta["cache_creation_input_tokens"] += usage.get(
                        "cache_creation_input_tokens", 0
                    )
                    meta["cache_read_input_tokens"] += usage.get(
                        "cache_read_input_tokens", 0
                    )
                    turn_context = (
                        usage.get("input_tokens", 0)
                        + usage.get("cache_creation_input_tokens", 0)
                        + usage.get("cache_read_input_tokens", 0)
                    )
                    meta["peak_context"] = max(meta["peak_context"], turn_context)
    except (IOError, OSError):
        pass

    return meta


def load_cache():
    """Load the metadata cache; returns {} on any version mismatch or error."""
    try:
        with open(CACHE_FILE) as f:
            data = json.load(f)
        if data.get("version") == CACHE_VERSION:
            return data.get("entries", {})
    except (IOError, OSError, ValueError):
        pass
    return {}


def save_cache(entries):
    """Atomically write the metadata cache (best-effort)."""
    try:
        tmp = CACHE_FILE.with_suffix(".tmp")
        with open(tmp, "w") as f:
            json.dump({"version": CACHE_VERSION, "entries": entries}, f)
        tmp.replace(CACHE_FILE)
    except (IOError, OSError):
        pass


def load_names():
    """Load user-assigned session names ({session_id: name})."""
    try:
        with open(NAMES_FILE) as f:
            data = json.load(f)
        if isinstance(data, dict):
            return data
    except (IOError, OSError, ValueError):
        pass
    return {}


def save_names(names):
    """Atomically write the session-names sidecar (best-effort)."""
    try:
        tmp = NAMES_FILE.with_suffix(".tmp")
        with open(tmp, "w") as f:
            json.dump(names, f, indent=2)
        tmp.replace(NAMES_FILE)
    except (IOError, OSError):
        pass


def merge_history_only(sessions):
    """Add sessions that exist only in history.jsonl (transcript was deleted).

    The live index is built from transcripts; this is a supplementary pass so
    that cleaned-up sessions still appear (marked '-') and stay searchable.
    """
    if not HISTORY_FILE.exists():
        return

    seen = set(sessions)
    extra = {}
    try:
        with open(HISTORY_FILE) as f:
            for line in f:
                try:
                    d = json.loads(line)
                except json.JSONDecodeError:
                    continue

                sid = d.get("sessionId", "")
                if not sid or sid in seen:
                    continue

                ts = to_ms(d.get("timestamp"))
                s = extra.get(sid)
                if s is None:
                    s = extra[sid] = {
                        "id": sid,
                        "project": d.get("project", ""),
                        "cwd": d.get("project", ""),
                        "git_branch": "",
                        "first_ts": ts,
                        "last_ts": ts,
                        "messages": [],
                        "msg_count": 0,
                        "first_assistant": "",
                        "model": None,
                        "input_tokens": 0,
                        "output_tokens": 0,
                        "cache_creation_input_tokens": 0,
                        "cache_read_input_tokens": 0,
                        "turns": 0,
                        "peak_context": 0,
                        "has_transcript": False,
                    }

                disp = d.get("display", "")
                if disp:
                    s["messages"].append(disp)
                    s["msg_count"] += 1
                if ts:
                    if not s["first_ts"] or ts < s["first_ts"]:
                        s["first_ts"] = ts
                    s["last_ts"] = max(s["last_ts"], ts)
    except (IOError, OSError):
        return

    sessions.update(extra)


def build_index():
    """Scan projects/ for transcripts and return (sessions, transcripts).

    Each transcript is the source of truth for one session. Files whose
    mtime+size match the cache reuse their parsed metadata; only changed (or
    new) files are re-read. Subagent transcripts are excluded.
    """
    cache = load_cache()
    new_cache = {}
    sessions = {}
    transcripts = {}

    if PROJECTS_DIR.exists():
        for jsonl in PROJECTS_DIR.rglob("*.jsonl"):
            if "subagents" in str(jsonl):
                continue
            sid = jsonl.stem
            key = str(jsonl)

            try:
                st = jsonl.stat()
            except OSError:
                continue

            cached = cache.get(key)
            if (
                cached
                and cached.get("mtime") == st.st_mtime
                and cached.get("size") == st.st_size
            ):
                meta = cached["meta"]
            else:
                meta = parse_transcript(jsonl)

            new_cache[key] = {"mtime": st.st_mtime, "size": st.st_size, "meta": meta}
            transcripts[sid] = jsonl

            session = dict(meta)
            session["id"] = sid
            session["project"] = meta.get("cwd", "")
            session["has_transcript"] = True
            sessions[sid] = session

    merge_history_only(sessions)

    names = load_names()
    for sid, session in sessions.items():
        session["name"] = names.get(sid, "")

    if new_cache != cache:
        save_cache(new_cache)

    return sessions, transcripts


def parse_terms(query):
    """Split a search query into lowercased whitespace-separated terms."""
    return [t for t in (query or "").lower().split() if t]


def terms_match(text, terms, any_mode):
    """AND (default) or OR (any_mode) membership of terms in text."""
    low = text.lower()
    return any(t in low for t in terms) if any_mode else all(t in low for t in terms)


def make_snippet(text, term, width=88):
    """Return a one-line window of `text` centered on the first hit of `term`."""
    text = re.sub(r"\s+", " ", text).strip()
    i = text.lower().find(term.lower())
    if i < 0:
        return text[:width]
    start = max(0, i - width // 3)
    snip = text[start:start + width]
    if start > 0:
        snip = "…" + snip
    if start + width < len(text):
        snip = snip + "…"
    return snip


def first_snippet(messages, terms):
    """First snippet from the first message that contains any term."""
    for m in messages:
        low = m.lower()
        for t in terms:
            if t in low:
                return make_snippet(m, t)
    return ""


def search_transcripts(terms, transcripts, any_mode=False):
    """Full-text search of transcript files.

    Returns {session_id: snippet} for matches. AND mode requires every term to
    appear somewhere in the file (not necessarily the same line); the snippet is
    taken from the first matching line.
    """
    matches = {}
    needed = len(terms)

    for sid, path in transcripts.items():
        seen = set()
        snippet = ""
        try:
            with open(path) as f:
                for line in f:
                    low = line.lower()
                    hits = [t for t in terms if t in low]
                    if hits:
                        if not snippet:
                            snippet = make_snippet(line, hits[0])
                        seen.update(hits)
                        if any_mode or len(seen) == needed:
                            break
        except (IOError, OSError):
            continue

        if (any_mode and seen) or (not any_mode and len(seen) == needed):
            matches[sid] = snippet

    return matches


def parse_when(spec):
    """Parse a time spec into epoch ms, or None.

    Accepts relative forms '30m', '24h', '7d', '2w' and absolute 'YYYY-MM-DD'.
    """
    if not spec:
        return None
    s = str(spec).strip().lower()
    m = re.match(r"^(\d+)\s*([mhdw])$", s)
    if m:
        mult = {"m": 60_000, "h": 3_600_000, "d": 86_400_000, "w": 604_800_000}[m.group(2)]
        return int(datetime.now().timestamp() * 1000 - int(m.group(1)) * mult)
    try:
        return int(datetime.strptime(s, "%Y-%m-%d").timestamp() * 1000)
    except ValueError:
        return None


# ─── Formatting Helpers ──────────────────────────────────────────────────────


def estimate_cost(usage, model=None):
    """Estimate USD cost from token usage."""
    rates = _best_match(model, PRICING)

    cost = 0.0
    cost += (usage["input_tokens"] / 1_000_000) * rates.get("input", 0)
    cost += (usage["output_tokens"] / 1_000_000) * rates.get("output", 0)
    cost += (usage["cache_creation_input_tokens"] / 1_000_000) * rates.get("cache_write", 0)
    cost += (usage["cache_read_input_tokens"] / 1_000_000) * rates.get("cache_read", 0)
    return cost


def cache_reuse_ratio(usage):
    """Fraction of input-side tokens served from cache (reads / all input).

    High write with low reads ⇒ low reuse ⇒ cache dollars spent without payoff.
    """
    read = usage.get("cache_read_input_tokens", 0)
    denom = read + usage.get("cache_creation_input_tokens", 0) + usage.get("input_tokens", 0)
    return (read / denom) if denom else 0.0


def format_tokens(n):
    """Format token count for display."""
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.1f}K"
    return str(n)


def format_size(size_bytes):
    """Format byte count for display."""
    for unit in ("B", "KB", "MB", "GB"):
        if size_bytes < 1024:
            return f"{size_bytes:.1f}{unit}" if unit != "B" else f"{size_bytes}{unit}"
        size_bytes /= 1024
    return f"{size_bytes:.1f}TB"


def format_timestamp(ts):
    """Convert millisecond timestamp to readable date."""
    if not ts:
        return "?"
    try:
        return datetime.fromtimestamp(ts / 1000).strftime("%Y-%m-%d %H:%M")
    except (ValueError, OSError):
        return "?"


def project_short_name(project_path):
    """Extract short project name from full path."""
    if not project_path:
        return "~"
    return os.path.basename(project_path) or "~"


def get_session_dir_size(transcripts, sid):
    """Get total size including subagent transcripts."""
    path = transcripts.get(sid)
    if not path:
        return 0

    total = 0
    session_dir = path.parent / sid

    try:
        total += path.stat().st_size
    except OSError:
        pass

    if session_dir.is_dir():
        for f in session_dir.rglob("*"):
            try:
                if f.is_file():
                    total += f.stat().st_size
            except OSError:
                pass

    return total


def resolve_session_id(prefix, sessions, transcripts):
    """Resolve a short prefix to a full session ID."""
    matches = []
    for sid in set(list(sessions.keys()) + list(transcripts.keys())):
        if sid.startswith(prefix):
            matches.append(sid)
    if len(matches) == 1:
        return matches[0]
    if len(matches) == 0:
        return None
    return matches


def resume_command(session):
    """Build the shell command that resumes this session.

    Claude Code resume is project-scoped, so prepend a `cd` into the session's
    working directory unless we're already there.
    """
    sid = session["id"]
    cwd = session.get("cwd") or session.get("project") or ""
    if cwd and os.path.realpath(cwd) != os.path.realpath(os.getcwd()):
        return f"cd {shlex.quote(cwd)} && claude --resume {sid}"
    return f"claude --resume {sid}"


