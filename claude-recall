# Short farewells / greetings / acks that don't describe what a session was
# about — skipped when choosing the prompt to show as a listing label.
TRIVIAL_PROMPTS = frozenset({
    "goodbye", "bye", "byebye", "bye bye", "catch you later", "see ya", "see you",
    "see you later", "later", "cya", "ciao", "adios", "peace", "good night",
    "goodnight", "gn", "night", "thanks", "thank you", "thanks so much", "thx",
    "ty", "ok", "okay", "k", "kk", "cool", "nice", "great", "awesome", "perfect",
    "good", "good job", "done", "yes", "no", "yep", "nope", "yeah", "sure",
    "exit", "quit", "stop", "hi", "hello", "hey", "yo", "sup", "test", "testing",
})


def is_trivial_prompt(text):
    """True for slash-commands and short farewells/greetings/acks — these make
    poor listing labels because they don't describe the session."""
    t = text.strip().lower().strip("!.?,…").strip()
    if not t or t.startswith("/"):
        return True
    if t.startswith("(") and t.endswith(")"):
        return True  # bracketed placeholder like "(no content)"
    if t.startswith("this session is being continued from a previous conversation"):
        return True  # compaction-summary boilerplate, not a real prompt
    return t in TRIVIAL_PROMPTS


def session_prompts(session, limit=2):
    """Up to `limit` substantive prompts to show for a session, in chronological
    order — skipping farewells/acks, slash-commands, and placeholder turns. For
    long sessions this returns the **opening prompt plus the most recent ones**
    (bookends), so a row conveys both what the session was about and where it
    ended. Falls back to the first thing Claude said; [] if nothing meaningful."""
    subs = [
        m for m in session.get("messages", [])
        if m and len(m) > 5 and "Caveat:" not in m and not is_trivial_prompt(m)
    ]
    if not subs:
        fa = session.get("first_assistant", "")
        return [fa] if fa and not is_trivial_prompt(fa) else []
    if limit <= 1:
        return [subs[0]]
    if len(subs) <= limit:
        chosen = subs
    else:
        chosen = [subs[0]] + subs[-(limit - 1):]  # opening + most-recent (limit-1)
    # Drop adjacent duplicates (same prompt repeated) while preserving order.
    out = []
    for m in chosen:
        if not out or out[-1] != m:
            out.append(m)
    return out


# Claude Code's `/color` palette → ANSI codes. These mirror the colors Claude
# itself stores per session (the `agent-color` transcript line), so a session
# shows the same color here as in Claude Code. "default"/unknown/"" = no color.
_COLOR_CODES = {
    "red": "31", "green": "32", "yellow": "33", "blue": "34",
    "purple": "35", "cyan": "36", "pink": "38;5;213", "orange": "38;5;208",
}
# Color only when writing to a real terminal, and honor the NO_COLOR convention.
USE_COLOR = sys.stdout.isatty() and os.environ.get("NO_COLOR") is None


def colorize(text, color):
    """Wrap text in the ANSI code for a Claude session color. No-op when output
    isn't a TTY, NO_COLOR is set, or the color is empty/default/unknown."""
    code = _COLOR_CODES.get((color or "").lower())
    if not USE_COLOR or not code:
        return text
    return "\033[{}m{}\033[0m".format(code, text)


def print_session(session, transcripts, show_tokens=False, show_size=False,
                  show_context=False, lines=2, snippet="", show_last=False):
    """Print a single session entry."""
    sid = session["id"]
    start = format_timestamp(session["first_ts"])
    proj = project_short_name(session["project"])
    branch = session.get("git_branch") or ""
    if branch and branch not in ("main", "master", "HEAD"):
        proj = f"{proj}@{branch}"
    proj = proj[:26]
    count = session["msg_count"]
    has_transcript = "+" if sid in transcripts else "-"

    # The row leads with the opening substantive prompt (or the assigned name);
    # any further prompts print as indented continuation lines below.
    color = session.get("color") or ""
    # Prefer a claude-recall sidecar name; otherwise fall back to Claude's own
    # session title (`/name`/`/rename` → custom_title) so named sessions show it.
    name = session.get("name") or session.get("custom_title") or ""
    prompts = session_prompts(session, lines)
    head = prompts[0] if prompts else ""
    name_tag = f"★ {name}" if name else ""
    if name_tag:
        label = f"{name_tag} — {head}" if head else name_tag
    else:
        label = head

    extras = ""

    if show_last:
        # When sorting by recent, show last activity so the ordering is obvious.
        extras += f"  [↻ {format_timestamp(session.get('last_ts', 0))}]"

    if show_size:
        if sid in transcripts:
            size = get_session_dir_size(transcripts, sid)
            extras += f"  [{format_size(size):>7}]"
        else:
            extras += f"  [{'---':>7}]"

    if show_tokens and sid in transcripts:
        cost = estimate_cost(session, session.get("model"))
        extras += f"  [${cost:.2f} | out:{format_tokens(session['output_tokens'])}]"
    elif show_tokens:
        extras += f"  [{'---':>18}]"

    if show_context and sid in transcripts:
        peak = session["peak_context"]
        flag = " ⚠" if context_warns(peak, session.get("model")) else ""
        extras += f"  [ctx:{format_tokens(peak)}{flag}]"
    elif show_context:
        extras += f"  [{'---':>10}]"

    # Truncate label to fit remaining width (on plain text, before coloring so
    # the ANSI escapes don't get counted or sliced mid-sequence).
    max_msg = max(30, 120 - len(extras) - 50)
    label = label[:max_msg]

    # Apply the session's own color: highlight the ★ name (the part the user
    # asked for) and tint the id so colored sessions are taggable even unnamed.
    if color:
        id_disp = colorize(sid[:8], color)
        if name_tag:
            nt = name_tag if len(name_tag) <= len(label) else label
            label = colorize(nt, color) + label[len(nt):]
    else:
        id_disp = sid[:8]

    print(
        f"  {start}  [{id_disp}] {has_transcript} "
        f"({count:>3} msgs)  {proj:<26}{extras}  {label}"
    )

    # A search snippet already supplies the match context; otherwise show the
    # remaining prompts as continuation lines (opening is shown inline above).
    if snippet:
        print(f"{'':>42}↳ {snippet}")
    else:
        for msg in prompts[1:]:
            print(f"{'':>42}{msg[:76]}")


def print_token_detail(session, transcripts):
    """Print detailed token usage for a session."""
    sid = session["id"]
    if sid not in transcripts:
        print(f"\n  Session: {sid[:8]}  |  No transcript on disk")
        return

    cost = estimate_cost(session, session.get("model"))
    model = session.get("model") or "unknown"
    size = get_session_dir_size(transcripts, sid)

    proj = project_short_name(session.get("project", ""))
    start = format_timestamp(session.get("first_ts", 0))
    peak = session["peak_context"]
    peak_flag = "  ⚠ near limit" if context_warns(peak, session.get("model")) else ""
    reuse = cache_reuse_ratio(session)

    print(f"\n  Session: {sid[:8]}  |  {start}  |  {proj}  |  Model: {model}")
    if session.get("name"):
        print(f"  {'Name:':<20} ★ {session['name']}")
    print(f"  {'Input:':<20} {format_tokens(session['input_tokens']):>8}")
    print(f"  {'Output:':<20} {format_tokens(session['output_tokens']):>8}")
    print(f"  {'Cache write:':<20} {format_tokens(session['cache_creation_input_tokens']):>8}")
    print(f"  {'Cache read:':<20} {format_tokens(session['cache_read_input_tokens']):>8}")
    print(f"  {'Cache reuse:':<20} {reuse * 100:>7.0f}%")
    print(f"  {'Peak context:':<20} {format_tokens(peak):>8}{peak_flag}")
    print(f"  {'API turns:':<20} {session['turns']:>8}")
    print(f"  {'Disk:':<20} {format_size(size):>8}")
    print(f"  {'Est. cost:':<20} {'$' + f'{cost:.2f}':>8}")
    print(f"  {'Resume:':<20} {resume_command(session)}")


